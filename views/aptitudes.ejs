<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Puestos/Cargos — SkillBoard</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root {
      --rojo:#C0392B; --rojo2:#E74C3C;
      --gris:#141414; --gris2:#1e1e1e; --gris3:#2a2a2a; --gris4:#333;
      --blanco:#F0EFEB; --texto:#888;
      --verde:#27AE60; --verde2:#2ecc71;
    }
    body { background:var(--gris); font-family:'Barlow',sans-serif; color:var(--blanco); min-height:100vh; display:flex; }

    /* ── SIDEBAR ── */
    .sidebar { width:240px; min-height:100vh; background:var(--gris2); border-right:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; position:fixed; top:0; left:0; z-index:100; }
    .sidebar-logo { padding:20px 24px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:12px; }
    .sidebar-logo .logo-img { width:38px; height:38px; object-fit:contain; flex-shrink:0; }
    .sidebar-logo .logo-text { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:800; letter-spacing:2px; text-transform:uppercase; line-height:1.1; color:var(--blanco); }
    .sidebar-logo .logo-text span { display:block; font-size:9px; font-weight:500; color:var(--texto); letter-spacing:3px; margin-top:2px; }
    .sidebar-nav { flex:1; padding:20px 0; }
    .nav-section { padding:8px 24px 4px; font-size:10px; font-weight:600; color:var(--texto); letter-spacing:2px; text-transform:uppercase; }
    .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:var(--texto); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.15s; border-left:3px solid transparent; }
    .nav-item:hover { color:var(--blanco); background:rgba(255,255,255,0.04); }
    .nav-item.active { color:var(--blanco); background:rgba(192,57,43,0.12); border-left-color:var(--rojo); }
    .nav-item svg { width:18px; height:18px; stroke:currentColor; fill:none; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; flex-shrink:0; }
    .sidebar-footer { padding:20px 24px; border-top:1px solid rgba(255,255,255,0.05); }
    .user-info { display:flex; align-items:center; gap:12px; margin-bottom:14px; }
    .user-avatar { width:36px; height:36px; background:var(--rojo); display:flex; align-items:center; justify-content:center; font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:700; color:white; flex-shrink:0; }
    .user-name { font-size:13px; font-weight:600; color:var(--blanco); }
    .user-role { font-size:11px; color:var(--texto); }
    .btn-logout { display:flex; align-items:center; gap:8px; width:100%; padding:9px 14px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07); color:var(--texto); font-family:'Barlow',sans-serif; font-size:13px; cursor:pointer; transition:all 0.15s; text-decoration:none; }
    .btn-logout:hover { background:rgba(192,57,43,0.15); border-color:var(--rojo); color:var(--rojo2); }
    .btn-logout svg { width:15px; height:15px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; }

    /* ── MAIN ── */
    .main { margin-left:240px; flex:1; display:flex; flex-direction:column; }
    .topbar { padding:20px 36px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:space-between; background:var(--gris2); }
    .topbar h1 { font-family:'Barlow Condensed',sans-serif; font-size:26px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
    .topbar p { font-size:13px; color:var(--texto); margin-top:2px; }

    .content { padding:28px 36px; flex:1; }

    /* MENSAJES */
    .success-msg { display:flex; align-items:center; gap:10px; background:rgba(39,174,96,0.1); border-left:3px solid var(--verde); color:var(--verde2); font-size:13px; padding:12px 16px; margin-bottom:20px; }
    .success-msg svg { width:15px; height:15px; stroke:var(--verde2); fill:none; stroke-width:2; flex-shrink:0; }
    .error-msg { display:flex; align-items:center; gap:10px; background:rgba(192,57,43,0.12); border-left:3px solid var(--rojo); color:#e07070; font-size:13px; padding:12px 16px; margin-bottom:20px; }
    .error-msg svg { width:15px; height:15px; stroke:#e07070; fill:none; stroke-width:2; flex-shrink:0; }

    /* FORM NUEVO */
    .nueva-form { background:var(--gris2); border:1px solid rgba(255,255,255,0.06); padding:28px; margin-bottom:28px; }
    .nueva-form h3 { font-family:'Barlow Condensed',sans-serif; font-size:15px; font-weight:700; text-transform:uppercase; letter-spacing:2px; color:var(--texto); margin-bottom:18px; }
    .form-row { display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap; }
    .field { flex:1; min-width:160px; }
    .field label { display:block; font-size:10px; font-weight:700; color:var(--texto); letter-spacing:2px; text-transform:uppercase; margin-bottom:8px; }
    .field input {
      width:100%; background:var(--gris3);
      border:1px solid rgba(255,255,255,0.07);
      border-bottom:2px solid rgba(255,255,255,0.14);
      color:var(--blanco); font-family:'Barlow',sans-serif; font-size:14px;
      padding:12px 14px; outline:none; transition:border-color 0.2s;
    }
    .field input:focus { border-color:var(--rojo); }
    .field input::placeholder { color:rgba(255,255,255,0.18); }
    .btn-primary { display:inline-flex; align-items:center; gap:8px; padding:12px 22px; background:var(--rojo); color:white; font-family:'Barlow Condensed',sans-serif; font-size:14px; font-weight:700; letter-spacing:1px; text-transform:uppercase; border:none; cursor:pointer; transition:background 0.15s; white-space:nowrap; }
    .btn-primary:hover { background:var(--rojo2); }

    /* TABLA */
    .tabla-wrap { background:var(--gris2); border:1px solid rgba(255,255,255,0.05); overflow:hidden; }
    .tabla-header { padding:16px 24px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:space-between; }
    .tabla-header h3 { font-family:'Barlow Condensed',sans-serif; font-size:15px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
    .tabla-count { font-family:'Barlow Condensed',sans-serif; font-size:13px; color:var(--texto); }

    table { width:100%; border-collapse:collapse; }
    thead th { padding:12px 24px; font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--texto); text-align:left; border-bottom:1px solid rgba(255,255,255,0.06); background:rgba(255,255,255,0.02); }
    tbody tr { border-bottom:1px solid rgba(255,255,255,0.04); transition:background 0.15s; animation:fadeUp 0.3s ease both; }
    tbody tr:last-child { border-bottom:none; }
    tbody tr:hover { background:rgba(255,255,255,0.03); }
    @keyframes fadeUp { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
    td { padding:14px 24px; font-size:13px; vertical-align:middle; }

    .apt-nombre { font-weight:600; font-size:14px; }
    .apt-desc { color:var(--texto); font-size:12px; margin-top:2px; }
    .apt-count {
      font-family:'Barlow Condensed',sans-serif;
      font-size:22px; font-weight:700; color:var(--rojo2);
      display:inline-flex; align-items:center; gap:6px;
    }
    .apt-count span { font-size:11px; font-weight:400; color:var(--texto); font-family:'Barlow',sans-serif; }

    .acciones { display:flex; gap:6px; align-items:center; justify-content:flex-end; }
    .btn-edit-inline { padding:6px 14px; background:transparent; border:1px solid rgba(255,255,255,0.1); color:var(--texto); font-size:12px; cursor:pointer; transition:all 0.15s; font-family:'Barlow',sans-serif; }
    .btn-edit-inline:hover { color:var(--blanco); border-color:rgba(255,255,255,0.25); }
    .btn-delete { padding:6px 10px; background:transparent; border:1px solid rgba(192,57,43,0.2); color:rgba(192,57,43,0.5); font-size:12px; cursor:pointer; transition:all 0.15s; font-family:'Barlow',sans-serif; }
    .btn-delete:hover { background:rgba(192,57,43,0.12); color:var(--rojo2); border-color:var(--rojo); }

    /* EMPTY */
    .empty-state { padding:56px 32px; text-align:center; color:var(--texto); }
    .empty-state svg { width:44px; height:44px; stroke:var(--texto); fill:none; stroke-width:1.2; margin-bottom:14px; display:block; margin-inline:auto; }
    .empty-state p { font-size:14px; }

    /* MODAL */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:200; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal { background:var(--gris2); border:1px solid rgba(255,255,255,0.1); padding:36px; width:460px; max-width:90vw; animation:fadeUp 0.2s ease; }
    .modal h3 { font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:24px; }
    .modal .field { margin-bottom:18px; }
    .modal-actions { display:flex; gap:10px; margin-top:28px; }
    .btn-cancel { padding:12px 22px; background:transparent; border:1px solid rgba(255,255,255,0.1); color:var(--texto); font-family:'Barlow',sans-serif; font-size:13px; cursor:pointer; transition:all 0.15s; }
    .btn-cancel:hover { color:var(--blanco); border-color:rgba(255,255,255,0.25); }
    .btn-save { flex:1; padding:12px; background:var(--rojo); color:white; font-family:'Barlow Condensed',sans-serif; font-size:15px; font-weight:700; letter-spacing:2px; text-transform:uppercase; border:none; cursor:pointer; transition:background 0.15s; }
    .btn-save:hover { background:var(--rojo2); }
  </style>
  <link rel="stylesheet" href="/css/sidebar-responsive.css"/>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-logo">
    <img src="/img/logo.png" class="logo-img" alt="SkillBoard"/>
    <div class="logo-text">SkillBoard<span>Gestión de Personal</span></div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">Principal</div>
    <a href="/dashboard" class="nav-item"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
    <a href="/empleados" class="nav-item"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Empleados</a>
    <a href="/aptitudes" class="nav-item active"><svg viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>Puestos/Cargos</a>
    <a href="/carnets" class="nav-item"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>Carnets</a>
    <div class="nav-section" style="margin-top:12px">Visualización</div>
    <a href="/tv" class="nav-item" target="_blank"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Vista TV</a>
    <% if (usuario.nivel === 1) { %>
    <div class="nav-section" style="margin-top:12px">Administración</div>
    <a href="/tv/config" class="nav-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>Config TV</a>
    <a href="/usuarios" class="nav-item"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Usuarios</a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <div class="user-info">
      <div class="user-avatar"><%= usuario.nombre.charAt(0).toUpperCase() %></div>
      <div><div class="user-name"><%= usuario.nombre %></div><div class="user-role"><%= usuario.nivel === 1 ? 'Administrador' : 'Supervisor' %></div></div>
    </div>
    <a href="/logout" class="btn-logout"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Cerrar sesión</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div>
      <h1>Puestos/Cargos</h1>
      <p><%= aptitudes.length %> puesto<%= aptitudes.length !== 1 ? 's' : '' %> registrado<%= aptitudes.length !== 1 ? 's' : '' %></p>
    </div>
  </div>

  <div class="content">

    <% if (success) { %>
    <div class="success-msg">
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
      Puesto/cargo guardado correctamente.
    </div>
    <% } %>
    <% if (error) { %>
    <div class="error-msg">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%= error %>
    </div>
    <% } %>

    <% if (usuario.nivel === 1) { %>
    <div class="nueva-form">
      <h3>Nuevo Puesto/Cargo</h3>
      <form method="POST" action="/aptitudes">
        <div class="form-row">
          <div class="field">
            <label>Nombre *</label>
            <input type="text" name="nombre" required placeholder="Ej: Operador de grúa, Electricista..."/>
          </div>
          <div class="field">
            <label>Descripción (opcional)</label>
            <input type="text" name="descripcion" placeholder="Descripción breve..."/>
          </div>
          <button type="submit" class="btn-primary">+ Agregar</button>
        </div>
      </form>
    </div>
    <% } %>

    <div class="tabla-wrap">
      <div class="tabla-header">
        <h3>Lista de Puestos/Cargos</h3>
        <span class="tabla-count"><%= aptitudes.length %> registrado<%= aptitudes.length !== 1 ? 's' : '' %></span>
      </div>

      <% if (aptitudes.length === 0) { %>
      <div class="empty-state">
        <svg viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        <p>No hay puestos/cargos creados aún. Agregá el primero arriba.</p>
      </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th style="text-align:center">Empleados</th>
            <% if (usuario.nivel === 1) { %><th></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% aptitudes.forEach((apt, i) => { %>
          <tr style="animation-delay:<%- i * 0.04 %>s">
            <td>
              <div class="apt-nombre"><%= apt.nombre %></div>
            </td>
            <td class="apt-desc"><%= apt.descripcion || '—' %></td>
            <td style="text-align:center">
              <div class="apt-count">
                <%= apt.total_empleados %>
                <span>empleado<%= apt.total_empleados !== 1 ? 's' : '' %></span>
              </div>
            </td>
            <% if (usuario.nivel === 1) { %>
            <td>
              <div class="acciones">
                <button class="btn-edit-inline"
                  onclick="abrirEditar(<%= apt.id %>, '<%= apt.nombre.replace(/'/g, "\\'") %>', '<%= (apt.descripcion||'').replace(/'/g, "\\'") %>')">
                  Editar
                </button>
                <form method="POST" action="/aptitudes/<%= apt.id %>/borrar"
                  onsubmit="return confirm('¿Eliminar el puesto/cargo «<%= apt.nombre %>»?')">
                  <button type="submit" class="btn-delete">✕</button>
                </form>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

  </div>
</main>

<!-- MODAL EDITAR -->
<div class="modal-overlay" id="modal-editar">
  <div class="modal">
    <h3>Editar Puesto/Cargo</h3>
    <form id="form-editar" method="POST">
      <div class="field">
        <label>Nombre *</label>
        <input type="text" id="edit-nombre" name="nombre" required
          style="width:100%;background:var(--gris3);border:1px solid rgba(255,255,255,0.07);border-bottom:2px solid rgba(255,255,255,0.14);color:var(--blanco);font-family:'Barlow',sans-serif;font-size:14px;padding:12px 14px;outline:none;margin-bottom:0;transition:border-color 0.2s;"
          onfocus="this.style.borderColor='var(--rojo)'" onblur="this.style.borderColor='rgba(255,255,255,0.14)'"/>
      </div>
      <div class="field" style="margin-top:18px">
        <label>Descripción</label>
        <input type="text" id="edit-descripcion" name="descripcion" placeholder="Opcional"
          style="width:100%;background:var(--gris3);border:1px solid rgba(255,255,255,0.07);border-bottom:2px solid rgba(255,255,255,0.14);color:var(--blanco);font-family:'Barlow',sans-serif;font-size:14px;padding:12px 14px;outline:none;transition:border-color 0.2s;"
          onfocus="this.style.borderColor='var(--rojo)'" onblur="this.style.borderColor='rgba(255,255,255,0.14)'"/>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-cancel" onclick="cerrarModal()">Cancelar</button>
        <button type="submit" class="btn-save">Guardar</button>
      </div>
    </form>
  </div>
</div>

<script>
function abrirEditar(id, nombre, descripcion) {
  document.getElementById('form-editar').action = '/aptitudes/' + id + '/editar';
  document.getElementById('edit-nombre').value = nombre;
  document.getElementById('edit-descripcion').value = descripcion;
  document.getElementById('modal-editar').classList.add('open');
}
function cerrarModal() {
  document.getElementById('modal-editar').classList.remove('open');
}
document.getElementById('modal-editar').addEventListener('click', function(e) {
  if (e.target === this) cerrarModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') cerrarModal(); });
</script>
<script src="/js/sidebar-responsive.js"></script>
</body>
</html>
