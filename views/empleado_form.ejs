<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= empleado ? 'Editar' : 'Nuevo' %> Empleado — SkillBoard</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root {
      --rojo:#C0392B; --rojo2:#E74C3C;
      --gris:#141414; --gris2:#1e1e1e; --gris3:#2a2a2a; --gris4:#333;
      --blanco:#F0EFEB; --texto:#888;
      --verde:#27AE60; --verde2:#2ecc71;
    }
    body { background:var(--gris); font-family:'Barlow',sans-serif; color:var(--blanco); min-height:100vh; display:flex; }

    /* ── SIDEBAR ── */
    .sidebar { width:240px; min-height:100vh; background:var(--gris2); border-right:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; position:fixed; top:0; left:0; z-index:100; }
    .sidebar-logo { padding:20px 24px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:12px; }
    .sidebar-logo .logo-img { width:38px; height:38px; object-fit:contain; flex-shrink:0; }
    .sidebar-logo .logo-text { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:800; letter-spacing:2px; text-transform:uppercase; line-height:1.1; color:var(--blanco); }
    .sidebar-logo .logo-text span { display:block; font-size:9px; font-weight:500; color:var(--texto); letter-spacing:3px; margin-top:2px; }
    .sidebar-nav { flex:1; padding:20px 0; }
    .nav-section { padding:8px 24px 4px; font-size:10px; font-weight:600; color:var(--texto); letter-spacing:2px; text-transform:uppercase; }
    .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:var(--texto); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.15s; border-left:3px solid transparent; }
    .nav-item:hover { color:var(--blanco); background:rgba(255,255,255,0.04); }
    .nav-item.active { color:var(--blanco); background:rgba(192,57,43,0.12); border-left-color:var(--rojo); }
    .nav-item svg { width:18px; height:18px; stroke:currentColor; fill:none; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; flex-shrink:0; }
    .sidebar-footer { padding:20px 24px; border-top:1px solid rgba(255,255,255,0.05); }
    .user-info { display:flex; align-items:center; gap:12px; margin-bottom:14px; }
    .user-avatar { width:36px; height:36px; background:var(--rojo); display:flex; align-items:center; justify-content:center; font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:700; color:white; flex-shrink:0; }
    .user-name { font-size:13px; font-weight:600; color:var(--blanco); }
    .user-role { font-size:11px; color:var(--texto); }
    .btn-logout { display:flex; align-items:center; gap:8px; width:100%; padding:9px 14px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07); color:var(--texto); font-family:'Barlow',sans-serif; font-size:13px; cursor:pointer; transition:all 0.15s; text-decoration:none; }
    .btn-logout:hover { background:rgba(192,57,43,0.15); border-color:var(--rojo); color:var(--rojo2); }
    .btn-logout svg { width:15px; height:15px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; }

    /* ── MAIN ── */
    .main { margin-left:240px; flex:1; display:flex; flex-direction:column; }
    .topbar { padding:20px 36px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:space-between; background:var(--gris2); }
    .topbar h1 { font-family:'Barlow Condensed',sans-serif; font-size:26px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
    .topbar p { font-size:13px; color:var(--texto); margin-top:2px; }
    .btn-back { display:inline-flex; align-items:center; gap:8px; padding:9px 18px; background:transparent; border:1px solid rgba(255,255,255,0.1); color:var(--texto); font-family:'Barlow',sans-serif; font-size:13px; text-decoration:none; transition:all 0.15s; }
    .btn-back:hover { color:var(--blanco); border-color:rgba(255,255,255,0.25); }

    .content { padding:32px 36px; max-width:700px; animation:fadeUp 0.4s ease both; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    /* ── FORM ── */
    .form-card { background:var(--gris2); border:1px solid rgba(255,255,255,0.06); padding:40px; }
    .form-section-title { font-family:'Barlow Condensed',sans-serif; font-size:12px; font-weight:700; color:var(--texto); letter-spacing:3px; text-transform:uppercase; margin-bottom:20px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.05); }

    .error-msg { display:flex; align-items:center; gap:10px; background:rgba(192,57,43,0.12); border-left:3px solid var(--rojo); color:#e07070; font-size:13px; padding:14px 18px; margin-bottom:28px; }
    .error-msg svg { width:16px; height:16px; stroke:#e07070; fill:none; stroke-width:2; flex-shrink:0; }

    .field { margin-bottom:22px; }
    .field label { display:block; font-size:11px; font-weight:600; color:var(--texto); letter-spacing:2px; text-transform:uppercase; margin-bottom:10px; }
    .field input[type=text], .field input[type=file] {
      width:100%; background:var(--gris3);
      border:1px solid rgba(255,255,255,0.07);
      border-bottom:2px solid rgba(255,255,255,0.14);
      color:var(--blanco); font-family:'Barlow',sans-serif; font-size:14px;
      padding:13px 16px; outline:none; transition:border-color 0.2s, background 0.2s;
    }
    .field input:focus { border-color:var(--rojo); background:#2f2f2f; }
    .field input::placeholder { color:rgba(255,255,255,0.18); }
    .field .hint { font-size:11px; color:var(--texto); margin-top:8px; line-height:1.5; }

    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; }

    /* FOTO */
    .foto-wrap { display:flex; align-items:flex-start; gap:20px; margin-bottom:8px; }
    .foto-preview { width:80px; height:80px; object-fit:cover; border:2px solid rgba(255,255,255,0.1); flex-shrink:0; }
    .foto-placeholder { width:80px; height:80px; background:var(--gris3); border:2px dashed rgba(255,255,255,0.12); display:flex; align-items:center; justify-content:center; flex-shrink:0; color:var(--texto); font-size:11px; text-align:center; padding:8px; }
    .foto-input-wrap { flex:1; }

    /* APTITUDES */
    .aptitudes-wrap { margin-top:4px; }
    .apt-add-row { display:flex; gap:8px; margin-bottom:12px; }
    .apt-add-row input { flex:1; background:var(--gris3); border:1px solid rgba(255,255,255,0.07); border-bottom:2px solid var(--rojo); color:var(--blanco); font-family:'Barlow',sans-serif; font-size:14px; padding:11px 14px; outline:none; }
    .apt-add-row input::placeholder { color:rgba(255,255,255,0.18); }
    .btn-apt-add { padding:11px 18px; background:var(--rojo); color:white; font-family:'Barlow Condensed',sans-serif; font-size:13px; font-weight:700; letter-spacing:1px; border:none; cursor:pointer; transition:background 0.15s; white-space:nowrap; }
    .btn-apt-add:hover { background:var(--rojo2); }
    .apt-msg { font-size:12px; margin-bottom:10px; display:none; }

    .aptitudes-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:8px; }
    .apt-check { display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--gris3); border:1px solid rgba(255,255,255,0.06); cursor:pointer; transition:border-color 0.15s; }
    .apt-check:hover { border-color:rgba(192,57,43,0.35); }
    .apt-check input[type=checkbox] { accent-color:var(--rojo); width:16px; height:16px; cursor:pointer; flex-shrink:0; }
    .apt-check span { font-size:13px; font-weight:500; }

    /* CARNETS */
    .carnets-wrap { display:flex; flex-direction:column; gap:10px; margin-top:8px; }
    .carnet-row { border:1px solid rgba(255,255,255,0.07); background:var(--gris3); padding:16px; }
    .carnet-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr 80px; gap:10px; align-items:end; }
    .carnet-grid .mini label { display:block; font-size:10px; color:var(--texto); margin-bottom:6px; letter-spacing:1px; text-transform:uppercase; }
    .carnet-grid input { width:100%; background:var(--gris2); border:1px solid rgba(255,255,255,0.08); border-bottom:2px solid rgba(255,255,255,0.12); color:var(--blanco); font-size:13px; padding:9px 10px; outline:none; font-family:'Barlow',sans-serif; transition:border-color 0.2s; }
    .carnet-grid input:focus { border-color:var(--rojo); }
    .carnet-grid input[type=number] { -moz-appearance:textfield; }
    .carnet-grid input[type=number]::-webkit-inner-spin-button,
    .carnet-grid input[type=number]::-webkit-outer-spin-button { -webkit-appearance:none; }
    .btn-remove-carnet { width:100%; padding:9px; background:transparent; border:1px solid rgba(192,57,43,0.25); color:rgba(192,57,43,0.6); cursor:pointer; font-size:14px; transition:all 0.15s; }
    .btn-remove-carnet:hover { background:rgba(192,57,43,0.12); color:var(--rojo2); border-color:var(--rojo); }
    .btn-add-carnet { margin-top:10px; padding:10px 16px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.3); color:var(--rojo2); font-size:13px; font-weight:600; cursor:pointer; font-family:'Barlow Condensed',sans-serif; letter-spacing:1px; transition:all 0.15s; }
    .btn-add-carnet:hover { background:rgba(192,57,43,0.2); }

    /* ACCIONES */
    .form-actions { display:flex; gap:12px; margin-top:36px; padding-top:28px; border-top:1px solid rgba(255,255,255,0.06); }
    .btn-submit { flex:1; padding:14px; background:var(--rojo); color:white; font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:700; letter-spacing:2px; text-transform:uppercase; border:none; cursor:pointer; transition:background 0.15s; }
    .btn-submit:hover { background:var(--rojo2); }
    .btn-cancel { padding:14px 28px; background:transparent; border:1px solid rgba(255,255,255,0.1); color:var(--texto); font-family:'Barlow',sans-serif; font-size:13px; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; transition:all 0.15s; }
    .btn-cancel:hover { color:var(--blanco); border-color:rgba(255,255,255,0.25); }
  </style>
  <link rel="stylesheet" href="/css/sidebar-responsive.css"/>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-logo">
    <img src="/img/logo.png" class="logo-img" alt="SkillBoard"/>
    <div class="logo-text">SkillBoard<span>Gestión de Personal</span></div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">Principal</div>
    <a href="/dashboard" class="nav-item"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
    <a href="/empleados" class="nav-item active"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Empleados</a>
    <a href="/aptitudes" class="nav-item"><svg viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>Puestos/Cargos</a>
    <a href="/carnets" class="nav-item"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>Carnets</a>
    <div class="nav-section" style="margin-top:12px">Visualización</div>
    <a href="/tv" class="nav-item" target="_blank"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Vista TV</a>
    <% if (usuario.nivel === 1) { %>
    <div class="nav-section" style="margin-top:12px">Administración</div>
    <a href="/tv/config" class="nav-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>Config TV</a>
    <a href="/usuarios" class="nav-item"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Usuarios</a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <div class="user-info">
      <div class="user-avatar"><%= usuario.nombre.charAt(0).toUpperCase() %></div>
      <div><div class="user-name"><%= usuario.nombre %></div><div class="user-role"><%= usuario.nivel === 1 ? 'Administrador' : 'Supervisor' %></div></div>
    </div>
    <a href="/logout" class="btn-logout"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Cerrar sesión</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div>
      <h1><%= empleado ? 'Editar Empleado' : 'Nuevo Empleado' %></h1>
      <p><%= empleado ? empleado.apellido + ', ' + empleado.nombre : 'Completá los datos del empleado' %></p>
    </div>
    <a href="/empleados" class="btn-back">← Volver</a>
  </div>

  <div class="content">
    <div class="form-card">
      <% if (error) { %>
      <div class="error-msg">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
      <% } %>

      <form method="POST" action="<%= empleado ? '/empleados/'+empleado.id+'/editar' : '/empleados' %>" enctype="multipart/form-data">

        <div class="form-section-title">Datos personales</div>

        <div class="field">
          <label>Foto de perfil</label>
          <div class="foto-wrap">
            <% if (empleado && empleado.foto) { %>
              <img src="/uploads/<%= empleado.foto %>" class="foto-preview" id="preview"/>
            <% } else { %>
              <div class="foto-placeholder" id="preview-placeholder">Sin foto</div>
              <img src="" class="foto-preview" id="preview" style="display:none"/>
            <% } %>
            <div class="foto-input-wrap">
              <input type="file" name="foto" accept="image/*" onchange="previewFoto(this)"/>
              <div class="hint">JPG, PNG o WEBP — máx. 5MB</div>
            </div>
          </div>
        </div>

        <div class="grid-2">
          <div class="field">
            <label>Nombre *</label>
            <input type="text" name="nombre" required placeholder="Juan" value="<%= empleado ? empleado.nombre : '' %>"/>
          </div>
          <div class="field">
            <label>Apellido *</label>
            <input type="text" name="apellido" required placeholder="García" value="<%= empleado ? empleado.apellido : '' %>"/>
          </div>
        </div>

        <div class="field">
          <label>Legajo *</label>
          <input type="text" name="legajo" required placeholder="001" value="<%= empleado ? empleado.legajo : '' %>"/>
          <div class="hint">Número único de identificación del empleado.</div>
        </div>

        <div class="form-section-title" style="margin-top:32px">Puesto/Cargo</div>

        <div class="field">
          <div class="aptitudes-wrap">
            <div class="apt-add-row">
              <input type="text" id="nueva-aptitud-input" placeholder="Escribí un nuevo puesto/cargo y presioná Agregar..."/>
              <button type="button" class="btn-apt-add" id="btn-agregar-aptitud">+ Agregar</button>
            </div>
            <div class="apt-msg" id="aptitud-msg"></div>
            <div class="aptitudes-grid" id="aptitudes-grid">
              <% aptitudes.forEach(apt => { %>
              <label class="apt-check">
                <input type="checkbox" name="aptitudes_sel" value="<%= apt.id %>"
                  <%= empleado && empleado.aptitudes_sel && empleado.aptitudes_sel.includes(apt.id) ? 'checked' : '' %>/>
                <span><%= apt.nombre %></span>
              </label>
              <% }) %>
              <% if (aptitudes.length === 0) { %>
              <p id="msg-sin-aptitudes" style="color:var(--texto);font-size:13px;grid-column:1/-1">
                No hay puestos/cargos creados aún. Escribí uno arriba y presioná Agregar.
              </p>
              <% } %>
            </div>
          </div>
        </div>

        <% if (!empleado) { %>
        <div class="form-section-title" style="margin-top:32px">Carnets (opcional)</div>
        <div class="field">
          <div class="hint" style="margin-bottom:12px">Podés cargar carnets del empleado al momento de crearlo.</div>
          <div id="carnets-wrap" class="carnets-wrap">
            <% const listaCarnets = carnetsDraft && carnetsDraft.length ? carnetsDraft : [{ especialidad:'', numero:'', fecha_emision:'', fecha_vencimiento:'', dias_alerta:30 }]; %>
            <% listaCarnets.forEach(c => { %>
            <div class="carnet-row">
              <div class="carnet-grid">
                <div class="mini"><label>Especialidad *</label><input type="text" name="carnet_especialidad" placeholder="Ej: Autoelevador" value="<%= c.especialidad %>"/></div>
                <div class="mini"><label>Número</label><input type="text" name="carnet_numero" placeholder="Opcional" value="<%= c.numero %>"/></div>
                <div class="mini"><label>Emisión *</label><input type="date" name="carnet_fecha_emision" value="<%= c.fecha_emision %>"/></div>
                <div class="mini"><label>Vencimiento *</label><input type="date" name="carnet_fecha_vencimiento" value="<%= c.fecha_vencimiento %>"/></div>
                <div class="mini"><label>Alerta (días)</label><input type="number" name="carnet_dias_alerta" min="1" max="365" step="1" value="<%= c.dias_alerta || 30 %>" onkeydown="return soloEnteros(event)" oninput="this.value=Math.floor(Math.abs(this.value)||30)"/></div>
              </div>
            </div>
            <% }) %>
          </div>
          <button type="button" class="btn-add-carnet" id="btn-add-carnet">+ Agregar otro carnet</button>
        </div>
        <% } %>

        <div class="form-actions">
          <a href="/empleados" class="btn-cancel">Cancelar</a>
          <button type="submit" class="btn-submit"><%= empleado ? 'Guardar cambios' : 'Crear empleado' %></button>
        </div>
      </form>
    </div>
  </div>
</main>

<script>
function previewFoto(input) {
  const preview = document.getElementById('preview');
  const placeholder = document.getElementById('preview-placeholder');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      preview.src = e.target.result;
      preview.style.display = 'block';
      if (placeholder) placeholder.style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
  }
}

function soloEnteros(e) {
  const permitidos = ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Enter','Home','End'];
  if (permitidos.includes(e.key)) return true;
  if (e.key >= '0' && e.key <= '9') return true;
  e.preventDefault(); return false;
}

async function agregarAptitud() {
  const input = document.getElementById('nueva-aptitud-input');
  const msg = document.getElementById('aptitud-msg');
  const nombre = input.value.trim();
  if (!nombre) return;

  msg.style.display = 'block';
  msg.style.color = 'var(--texto)';
  msg.textContent = 'Guardando...';

  try {
    const res = await fetch('/aptitudes', {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body:`nombre=${encodeURIComponent(nombre)}&descripcion=`
    });
    if (res.ok || res.redirected) {
      const res2 = await fetch('/api/aptitudes');
      const data = await res2.json();
      const nueva = data.find(a => a.nombre.toLowerCase() === nombre.toLowerCase());
      if (nueva) {
        const sinApt = document.getElementById('msg-sin-aptitudes');
        if (sinApt) sinApt.remove();
        const grid = document.getElementById('aptitudes-grid');
        const label = document.createElement('label');
        label.className = 'apt-check';
        label.innerHTML = `<input type="checkbox" name="aptitudes_sel" value="${nueva.id}" checked/><span>${nueva.nombre}</span>`;
        grid.appendChild(label);
        input.value = '';
        msg.style.color = 'var(--verde2)';
        msg.textContent = `✓ "${nueva.nombre}" agregado y seleccionado`;
        setTimeout(() => { msg.style.display = 'none'; }, 2500);
      }
    } else {
      msg.style.color = '#e07070';
      msg.textContent = 'Error al guardar. Puede que ya exista ese puesto/cargo.';
    }
  } catch(e) {
    msg.style.color = '#e07070';
    msg.textContent = 'Error de conexión.';
  }
}

document.getElementById('btn-agregar-aptitud').addEventListener('click', agregarAptitud);
document.getElementById('nueva-aptitud-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); agregarAptitud(); }
});

const btnAddCarnet = document.getElementById('btn-add-carnet');
if (btnAddCarnet) {
  btnAddCarnet.addEventListener('click', () => {
    const wrap = document.getElementById('carnets-wrap');
    const row = document.createElement('div');
    row.className = 'carnet-row';
    row.innerHTML = `
      <div class="carnet-grid">
        <div class="mini"><label>Especialidad *</label><input type="text" name="carnet_especialidad" placeholder="Ej: Autoelevador"/></div>
        <div class="mini"><label>Número</label><input type="text" name="carnet_numero" placeholder="Opcional"/></div>
        <div class="mini"><label>Emisión *</label><input type="date" name="carnet_fecha_emision"/></div>
        <div class="mini"><label>Vencimiento *</label><input type="date" name="carnet_fecha_vencimiento"/></div>
        <div class="mini"><label>Alerta (días)</label><input type="number" name="carnet_dias_alerta" min="1" max="365" step="1" value="30" onkeydown="return soloEnteros(event)" oninput="this.value=Math.floor(Math.abs(this.value)||30)"/></div>
      </div>
      <button type="button" class="btn-remove-carnet" style="margin-top:10px;width:auto;padding:6px 14px;" onclick="this.closest('.carnet-row').remove()">✕ Eliminar</button>
    `;
    wrap.appendChild(row);
  });
}
</script>
<script src="/js/sidebar-responsive.js"></script>
</body>
</html>
